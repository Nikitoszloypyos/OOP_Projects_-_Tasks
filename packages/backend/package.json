{
  "name": "@task-management/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:all": "ENABLED_MODULES=all tsx src/index.ts",
    "dev:users": "ENABLED_MODULES=users tsx src/index.ts",
    "dev:projects": "ENABLED_MODULES=users,projects tsx src/index.ts",
    "dev:tasks": "ENABLED_MODULES=users,projects,tasks tsx src/index.ts",
    "dev:comments": "ENABLED_MODULES=users,projects,tasks,comments tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
